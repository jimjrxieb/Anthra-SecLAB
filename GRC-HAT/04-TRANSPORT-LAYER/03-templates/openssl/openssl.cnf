# openssl.cnf — Hardened OpenSSL configuration
# NIST: SC-13 (cryptographic protection), IA-5 (authenticator management)
# Purpose: Enforce strong defaults for certificate generation, CSR creation, and CA operations.
# Deploy: export OPENSSL_CONF=/path/to/openssl.cnf before running openssl commands.
#
# WHY hardened defaults matter: openssl uses compiled-in defaults if no config is provided.
# Those defaults may allow MD5, SHA1, or weak key sizes. This config enforces policy.

[ default ]
# WHY SC-13: SHA-256 as default digest. SHA-1 is deprecated for certificate signing
# per NIST SP 800-131A. SHA-512 is acceptable but SHA-256 has better performance.
default_md = sha256

# WHY IA-5: Prompt for distinguished name fields — avoids accidents with wrong subject.
prompt = yes

# Default days for certificate validity when -days not specified.
# WHY: 365 days is a reasonable default for manual cert generation.
# For production, use shorter durations (90 days) and automate renewal.
default_days = 365

# WHY: 20 bytes = 160-bit serial numbers. Large random serials prevent collision.
# CA serial numbers must be unique — random generation is safer than sequential.
serial = /dev/urandom

####################################################################
[ req ]
# WHY SC-13: RSA 4096 as minimum key size for new keys.
# NIST SP 800-131A prohibits RSA < 2048. Use 4096 for CA keys, 2048+ for server keys.
# For EC keys, use ecparam section below — P-256 preferred.
default_bits = 4096
default_md   = sha256
prompt       = no
distinguished_name = req_distinguished_name
req_extensions     = v3_req
x509_extensions    = v3_ca

####################################################################
[ req_distinguished_name ]
# Default DN fields — override at command line with -subj
# WHY: Organizational fields provide context for certificate consumers.
countryName            = US
stateOrProvinceName    = Georgia
localityName           = Atlanta
organizationName       = SecLAB
organizationalUnitName = Security Operations
commonName             = localhost
emailAddress           = security@seclab.local

####################################################################
[ v3_req ]
# WHY SC-13: basicConstraints CA:FALSE — server/client certs should NOT be CA certs.
# If a server cert had CA:TRUE, it could sign other certs — privilege escalation.
basicConstraints = CA:FALSE

# WHY: keyUsage restricts what the key can be used for cryptographically.
# digitalSignature: for TLS handshake authentication (required).
# keyEncipherment: for RSA key exchange in TLS 1.2 (not needed for ECDHE-only).
# For ECDSA keys: remove keyEncipherment, it doesn't apply.
keyUsage = critical, digitalSignature, keyEncipherment

# WHY SC-23: extendedKeyUsage restricts to TLS server/client roles only.
# Without this, the cert could be misused for code signing or email encryption.
extendedKeyUsage = serverAuth, clientAuth

# WHY: subjectAltName is what modern clients use for hostname validation.
# RFC 2818 deprecated CommonName for host validation. SANs are required.
subjectAltName = @alt_names

[ alt_names ]
# CHANGE: Add your hostnames here. At minimum, DNS.1 = your primary domain.
DNS.1 = localhost
DNS.2 = *.localhost
# IP.1 = 127.0.0.1   # Uncomment to add IP SAN

####################################################################
[ v3_ca ]
# WHY IA-5: CA certificates have basicConstraints CA:TRUE to sign other certs.
# pathlen:0 means this CA cannot sign intermediate CA certs — leaf CA only.
# For root CA: omit pathlen. For intermediate CA: pathlen:0 is correct.
basicConstraints = critical, CA:TRUE, pathlen:0
subjectKeyIdentifier = hash
authorityKeyIdentifier = keyid:always, issuer:always

# WHY SC-13: CA key usage must include keyCertSign and cRLSign.
# keyCertSign: allows signing certificate requests.
# cRLSign: allows signing certificate revocation lists.
keyUsage = critical, keyCertSign, cRLSign, digitalSignature

####################################################################
[ v3_intermediate_ca ]
# For intermediate CA certificates (pathlen:0 = cannot create further CAs)
basicConstraints = critical, CA:TRUE, pathlen:0
subjectKeyIdentifier = hash
authorityKeyIdentifier = keyid:always, issuer:always
keyUsage = critical, keyCertSign, cRLSign, digitalSignature

####################################################################
[ ecparam ]
# WHY SC-13: ECDSA P-256 (prime256v1) is the NIST recommended curve.
# Provides 128-bit security with 256-bit key — equivalent to RSA 3072.
# P-384 provides 192-bit security for higher assurance requirements.
# DO NOT use P-521 — performance cost without practical security benefit.
# DO NOT use non-NIST curves (Curve25519) for FIPS environments.
curve = prime256v1

####################################################################
[ cipher_string ]
# WHY SC-13: Prohibit known-weak algorithms at the library level.
# These OpenSSL cipher string options exclude:
#   - RC4: stream cipher, statistical attacks
#   - 3DES/DES: SWEET32 birthday attack, deprecated
#   - NULL ciphers: no encryption
#   - EXPORT: intentionally weakened for export control (historical)
#   - MD5 MACs: collision attacks
#   - SSLv2/SSLv3: broken protocols
#
# Use in openssl commands: -cipher 'DEFAULT:!RC4:!3DES:!DES:!NULL:!EXPORT:!MD5:!SSLv2:!SSLv3'
# Or with modern TLS flag: -cipher 'ECDHE+AESGCM:ECDHE+CHACHA20'
#
# WHY we don't set this globally: OpenSSL config doesn't directly set cipher strings
# for s_client/s_server — these are set at the application layer. Document here for reference.
# Application cipher string:
CIPHERS = ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305
PROHIBITED = !RC4:!3DES:!DES:!NULL:!EXPORT:!MD5:!SSLv2:!SSLv3:!aNULL:!eNULL

####################################################################
# ─── Usage Examples ──────────────────────────────────────────────────────
# Generate EC private key:
#   OPENSSL_CONF=/path/openssl.cnf openssl ecparam -genkey -name prime256v1 -noout -out server.key
#
# Generate RSA private key (4096):
#   OPENSSL_CONF=/path/openssl.cnf openssl genrsa -out server.key 4096
#
# Generate CSR with this config:
#   OPENSSL_CONF=/path/openssl.cnf openssl req -new -key server.key -out server.csr
#
# Self-sign a cert (lab use only):
#   OPENSSL_CONF=/path/openssl.cnf openssl x509 -req -days 90 -sha256 \
#     -in server.csr -signkey server.key -out server.crt -extensions v3_req -extfile /path/openssl.cnf
#
# Generate CA cert:
#   OPENSSL_CONF=/path/openssl.cnf openssl req -new -x509 -days 3650 \
#     -key ca.key -out ca.crt -extensions v3_ca
#
# Verify cert against this policy:
#   openssl x509 -noout -text -in server.crt | grep -E "Signature Algorithm|Public Key|Subject Alt"
